# ─────────────────────────────────────────────────────────────────────────────
# CustomBot Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Environment variables take precedence over config.json where applicable.
# .env is already gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM ──────────────────────────────────────────────────────────────────────

# OpenAI-compatible API key. Overrides config.json > llm.api_key when set.
OPENAI_API_KEY=

# Base URL for the OpenAI-compatible API endpoint.
# Overrides config.json > llm.base_url when set.
OPENAI_BASE_URL=


# ── Rate Limiting ────────────────────────────────────────────────────────────

# Maximum chat messages per chat per minute. Clamped to [1, 100].
RATE_LIMIT_CHAT_PER_MINUTE=30

# Maximum expensive-skill invocations per chat per minute. Clamped to [1, 100].
RATE_LIMIT_EXPENSIVE_PER_MINUTES=10


# ── Scheduler ────────────────────────────────────────────────────────────────

# HMAC secret for signing scheduled-task payloads. When set, incoming webhook
# requests must carry a valid HMAC-SHA256 signature. Leave empty to disable.
SCHEDULER_HMAC_SECRET=


# ── Health Server ────────────────────────────────────────────────────────────

# Max HTTP requests per IP within the rate-limit window. Default: 60
HEALTH_HTTP_RATE_LIMIT=60

# Sliding window size in seconds for health server rate limiting. Default: 60
HEALTH_HTTP_RATE_WINDOW=60

# Maximum distinct IPs to track for rate limiting. Default: 500
HEALTH_HTTP_RATE_MAX_IPS=500

# Max request body size in bytes. Health endpoints are GET-only. Default: 1024
HEALTH_MAX_BODY_BYTES=1024

# Max URL path length in characters. Default: 2048
HEALTH_MAX_URL_LENGTH=2048

# Optional HMAC secret for authenticating health endpoint requests.
# When set, clients must include an Authorization: HMAC-SHA256 <signature> header.
HEALTH_HMAC_SECRET=


# ── OpenTelemetry Tracing ────────────────────────────────────────────────────

# Trace exporter type: "console" (default), "otlp", or "none" to disable.
OTEL_TRACES_EXPORTER=console

# Service name reported in traces. Default: custombot
OTEL_SERVICE_NAME=custombot

# OTLP collector endpoint. Only used when OTEL_TRACES_EXPORTER=otlp.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
